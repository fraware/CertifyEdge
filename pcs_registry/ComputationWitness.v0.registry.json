{
  "artifact_type": "ComputationWitness.v0",
  "schema": "schemas/ComputationWitness.v0.schema.json",
  "schema_owner": "pcs-core",
  "runtime_producer": "CertifyEdge",
  "allowed_runtime_producers": [
    "CertifyEdge"
  ],
  "producer": "CertifyEdge",
  "allowed_statuses": [
    "CertificateChecked",
    "Rejected",
    "Stale"
  ],
  "required_release_fields": [
    "schema_version",
    "certificate_id",
    "run_hash",
    "dataset_receipt_hash",
    "environment_receipt_hash",
    "code_commit",
    "property_id",
    "checker",
    "checker_version",
    "status",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "semantic_checks": [
    {
      "check_id": "dataset_hash_matches_receipt",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "environment_hash_matches_receipt",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "result_hashes_match_result_artifacts",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "code_commit_present",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "computation_status_checked_for_release",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    }
  ],
  "consumer_repos": [
    "Provability Fabric",
    "Scientific Memory"
  ],
  "canonical_hash_required": true,
  "release_mode_required": true
}
