{
  "artifact_type": "TraceCertificate.v0",
  "schema": "schemas/TraceCertificate.v0.schema.json",
  "schema_owner": "pcs-core",
  "producer": "CertifyEdge",
  "runtime_producer": "CertifyEdge",
  "allowed_statuses": [
    "CertificatePending",
    "CertificateChecked",
    "Rejected",
    "Stale"
  ],
  "required_release_fields": [
    "schema_version",
    "certificate_id",
    "trace_hash",
    "spec_hash",
    "property_id",
    "checker",
    "checker_version",
    "status",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "semantic_checks": [
    "trace_hash_matches_runtime_receipt",
    "status_is_certificate_checked_for_release",
    "source_commit_matches_release_manifest"
  ],
  "consumer_repos": [
    "CertifyEdge",
    "LabTrust-Gym",
    "Provability Fabric",
    "Scientific Memory"
  ],
  "canonical_hash_required": true,
  "release_mode_required": true
}
