{
  "artifact_type": "ToolUseCertificate.v0",
  "schema": "schemas/ToolUseCertificate.v0.schema.json",
  "schema_owner": "pcs-core",
  "runtime_producer": "CertifyEdge",
  "allowed_runtime_producers": [
    "CertifyEdge"
  ],
  "producer": "CertifyEdge",
  "allowed_statuses": [
    "CertificateChecked",
    "Rejected",
    "Stale"
  ],
  "required_release_fields": [
    "schema_version",
    "certificate_id",
    "trace_hash",
    "policy_hash",
    "property_id",
    "checker",
    "checker_version",
    "status",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "semantic_checks": [
    {
      "check_id": "trace_hash_matches_runtime_receipt",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "policy_hash_matches_runtime_policy",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "status_is_certificate_checked_for_release",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    },
    {
      "check_id": "source_commit_matches_release_manifest",
      "severity": "release_blocking",
      "responsible_component": "CertifyEdge",
      "execution_required_in_release_mode": true,
      "allowed_to_skip": false
    }
  ],
  "consumer_repos": [
    "CertifyEdge",
    "Provability Fabric"
  ],
  "canonical_hash_required": true,
  "release_mode_required": true
}
