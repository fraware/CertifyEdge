{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fraware/CertifyEdge/templates/profiles/schema.json",
  "title": "CertifyEdgePropertyProfile",
  "type": "object",
  "required": [
    "property_id",
    "template",
    "input_trace_artifact",
    "output_certificate_artifact",
    "counterexample_artifact",
    "valid_success_status",
    "valid_failure_status",
    "release_mode_required_fields",
    "repair_hints",
    "formalization"
  ],
  "additionalProperties": false,
  "properties": {
    "property_id": {
      "type": "string",
      "minLength": 1
    },
    "template": {
      "type": "string",
      "minLength": 1
    },
    "input_trace_artifact": {
      "type": "string",
      "minLength": 1
    },
    "output_certificate_artifact": {
      "type": "string",
      "minLength": 1
    },
    "counterexample_artifact": {
      "type": "string",
      "minLength": 1
    },
    "valid_success_status": {
      "type": "string",
      "minLength": 1
    },
    "valid_failure_status": {
      "type": "string",
      "minLength": 1
    },
    "release_mode_required_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_release_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "repair_hints": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/profile_repair_hint"
      }
    },
    "supporting_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "formalization": {
      "$ref": "#/$defs/profile_formalization"
    }
  },
  "$defs": {
    "profile_repair_hint": {
      "type": "object",
      "required": ["kind", "command"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "responsible_component": { "type": "string", "minLength": 1 }
      }
    },
    "profile_formalization": {
      "type": "object",
      "required": ["certificate_predicate", "required_fields"],
      "additionalProperties": false,
      "properties": {
        "certificate_predicate": { "type": "string", "minLength": 1 },
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "admissible_status": { "type": "string", "minLength": 1 },
        "rejected_status": { "type": "string", "minLength": 1 },
        "stale_status": { "type": "string", "minLength": 1 }
      }
    }
  }
}
