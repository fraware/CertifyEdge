{
  "property_id": "agent_tool_use.safety_v0",
  "template": "templates/tool_use/no_unauthorized_tool.stl",
  "input_trace_artifact": "ToolUseTrace.v0",
  "output_certificate_artifact": "ToolUseCertificate.v0",
  "counterexample_artifact": "ToolUseCounterexample.v0",
  "valid_success_status": "CertificateChecked",
  "valid_failure_status": "Rejected",
  "release_mode_required_fields": [
    "trace_hash",
    "policy_hash",
    "property_id",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "formalization": {
    "certificate_predicate": "CertificateMatchesRuntime",
    "required_fields": [
      "certificate_id",
      "trace_hash",
      "policy_hash",
      "status",
      "source_repo",
      "source_commit",
      "signature_or_digest"
    ],
    "admissible_status": "CertificateChecked",
    "rejected_status": "Rejected",
    "stale_status": "Stale"
  },
  "repair_hints": {
    "unauthorized_tool_call": {
      "kind": "fix_trace_or_policy",
      "command": "regenerate runtime trace after policy enforcement",
      "responsible_component": "runtime_producer"
    },
    "policy_hash_missing": {
      "kind": "fix_trace_or_policy",
      "command": "ensure tool-use trace includes policy_hash before certification",
      "responsible_component": "runtime_producer"
    },
    "unknown_authorization_status": {
      "kind": "fix_trace_or_policy",
      "command": "normalize tool authorization_status to authorized or rejected before certification",
      "responsible_component": "runtime_producer"
    },
    "policy_hash_mismatch": {
      "kind": "fix_trace_or_policy",
      "command": "regenerate tool-use trace and handoff with matching policy_hash invariant",
      "responsible_component": "runtime_producer"
    }
  }
}
