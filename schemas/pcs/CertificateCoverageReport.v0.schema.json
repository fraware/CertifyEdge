{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/CertificateCoverageReport.v0.schema.json",
  "title": "CertificateCoverageReport.v0",
  "type": "object",
  "required": [
    "schema_version",
    "artifact",
    "profile_id",
    "cases_dir",
    "valid_certificates_accepted",
    "valid_cases_total",
    "invalid_certificates_rejected",
    "invalid_cases_total",
    "failure_code_accuracy",
    "counterexample_completeness",
    "profile_resolution_accuracy",
    "handoff_validation_accuracy",
    "repair_hint_metrics",
    "profile_coverage",
    "case_results"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "artifact": { "const": "CertificateCoverageReport.v0" },
    "profile_id": { "type": "string", "minLength": 1 },
    "cases_dir": { "type": "string", "minLength": 1 },
    "valid_certificates_accepted": { "type": "integer", "minimum": 0 },
    "valid_cases_total": { "type": "integer", "minimum": 0 },
    "invalid_certificates_rejected": { "type": "integer", "minimum": 0 },
    "invalid_cases_total": { "type": "integer", "minimum": 0 },
    "failure_code_accuracy": { "$ref": "common.defs.json#/$defs/unit_ratio" },
    "counterexample_completeness": { "$ref": "common.defs.json#/$defs/unit_ratio" },
    "profile_resolution_accuracy": { "$ref": "common.defs.json#/$defs/unit_ratio" },
    "handoff_validation_accuracy": { "$ref": "common.defs.json#/$defs/unit_ratio" },
    "repair_hint_metrics": { "$ref": "common.defs.json#/$defs/repair_hint_metrics" },
    "profile_coverage": {
      "type": "object",
      "required": [
        "schema_version",
        "artifact",
        "profile_id",
        "templates_checked",
        "valid_cases",
        "invalid_cases",
        "properties_covered",
        "counterexample_types_covered",
        "unsupported_cases",
        "coverage_score"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
        "artifact": { "const": "ProfileCoverageReport.v0" },
        "profile_id": { "type": "string", "minLength": 1 },
        "templates_checked": { "type": "boolean" },
        "valid_cases": { "type": "integer", "minimum": 0 },
        "invalid_cases": { "type": "integer", "minimum": 0 },
        "properties_covered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "counterexample_types_covered": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "unsupported_cases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "coverage_score": { "$ref": "common.defs.json#/$defs/unit_ratio" }
      }
    },
    "case_results": {
      "type": "array",
      "items": { "$ref": "common.defs.json#/$defs/benchmark_case_run_result" }
    }
  }
}
