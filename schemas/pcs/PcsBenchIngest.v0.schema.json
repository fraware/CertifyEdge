{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/PcsBenchIngest.v0.schema.json",
  "title": "PcsBenchIngest.v0",
  "type": "object",
  "required": [
    "schema_version",
    "producer_id",
    "suite_id",
    "workflow_id",
    "benchmark_runs",
    "coverage_reports",
    "failure_localization_reports",
    "explain_quality_reports",
    "profile_coverage_reports",
    "commands",
    "logs",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "producer_id": { "$ref": "common.defs.json#/$defs/benchmark_producer_id" },
    "suite_id": { "type": "string", "minLength": 1 },
    "workflow_id": { "type": "string", "minLength": 1 },
    "benchmark_runs": {
      "type": "array",
      "items": { "$ref": "BenchmarkRun.v0.schema.json" }
    },
    "coverage_reports": {
      "type": "array",
      "items": { "$ref": "CoverageReport.v0.schema.json" }
    },
    "failure_localization_reports": {
      "type": "array",
      "items": { "$ref": "FailureLocalizationResult.v0.schema.json" }
    },
    "explain_quality_reports": {
      "type": "array",
      "items": { "$ref": "ExplainQualityReport.v0.schema.json" }
    },
    "profile_coverage_reports": {
      "type": "array",
      "items": { "$ref": "ProfileCoverageReport.v0.schema.json" }
    },
    "commands": {
      "type": "array",
      "items": { "$ref": "common.defs.json#/$defs/benchmark_command_entry" }
    },
    "logs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifact_refs": {
      "type": "array",
      "items": { "$ref": "BenchmarkArtifactRef.v0.schema.json" }
    },
    "source_repo": { "type": "string", "format": "uri" },
    "source_commit": { "$ref": "common.defs.json#/$defs/git_commit" },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  }
}
