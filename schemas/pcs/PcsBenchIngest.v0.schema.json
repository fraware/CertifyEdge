{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/PcsBenchIngest.v0.schema.json",
  "title": "PcsBenchIngest.v0",
  "description": "Single-file bundle for pcs-bench ingestion of CertifyEdge certificate benchmark output.",
  "type": "object",
  "required": [
    "schema_version",
    "artifact",
    "benchmark_suite_id",
    "workflow_profile_id",
    "producer_id",
    "benchmark_runs",
    "certificate_coverage_report",
    "profile_coverage_report",
    "repair_hint_quality",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "artifact": { "const": "PcsBenchIngest.v0" },
    "benchmark_suite_id": { "type": "string", "minLength": 1 },
    "workflow_profile_id": { "type": "string", "minLength": 1 },
    "producer_id": { "$ref": "common.defs.json#/$defs/benchmark_producer_id" },
    "benchmark_runs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/certificate_benchmark_run_v0" }
    },
    "certificate_coverage_report": {
      "$ref": "#/$defs/certificate_coverage_report_v0"
    },
    "profile_coverage_report": {
      "$ref": "#/$defs/profile_coverage_report_v0"
    },
    "repair_hint_quality": {
      "$ref": "#/$defs/coverage_report_v0"
    },
    "source_repo": { "type": "string", "format": "uri" },
    "source_commit": { "$ref": "common.defs.json#/$defs/git_commit" },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  }
}
