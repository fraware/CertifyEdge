{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/ExplainQualityReport.v0.schema.json",
  "title": "ExplainQualityReport.v0",
  "type": "object",
  "required": [
    "schema_version",
    "report_id",
    "suite_id",
    "case_id",
    "producer_id",
    "required_sections",
    "sections",
    "sections_present_count",
    "sections_required_count",
    "quality_score",
    "gaps",
    "source_repo",
    "source_commit",
    "signature_or_digest"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "report_id": { "type": "string", "minLength": 1 },
    "suite_id": { "type": "string", "minLength": 1 },
    "case_id": { "type": "string", "minLength": 1 },
    "producer_id": { "$ref": "common.defs.json#/$defs/benchmark_producer_id" },
    "workflow_id": { "type": "string", "minLength": 1 },
    "required_sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.defs.json#/$defs/explain_quality_section_id" }
    },
    "sections": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/section_quality" }
    },
    "sections_present_count": { "type": "integer", "minimum": 0 },
    "sections_required_count": { "type": "integer", "minimum": 0 },
    "quality_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/quality_gap" }
    },
    "source_repo": { "type": "string", "format": "uri" },
    "source_commit": { "$ref": "common.defs.json#/$defs/git_commit" },
    "signature_or_digest": { "$ref": "common.defs.json#/$defs/hex_digest" }
  },
  "$defs": {
    "section_quality": {
      "type": "object",
      "required": ["present", "score"],
      "additionalProperties": false,
      "properties": {
        "present": { "type": "boolean" },
        "score": { "type": "number", "minimum": 0, "maximum": 1 },
        "notes": { "type": "string" }
      }
    },
    "quality_gap": {
      "type": "object",
      "required": ["section_id", "message"],
      "additionalProperties": false,
      "properties": {
        "section_id": { "$ref": "common.defs.json#/$defs/explain_quality_section_id" },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
