{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pcs.sentinelops.ci/schemas/BenchmarkCaseSpec.v0.schema.json",
  "title": "BenchmarkCaseSpec.v0",
  "type": "object",
  "required": [
    "schema_version",
    "case_id",
    "profile_id",
    "kind",
    "handoff_file"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "$ref": "common.defs.json#/$defs/schema_version" },
    "case_id": { "type": "string", "minLength": 1 },
    "profile_id": { "type": "string", "minLength": 1 },
    "kind": { "$ref": "common.defs.json#/$defs/certificate_benchmark_folder_kind" },
    "case_category": {
      "$ref": "common.defs.json#/$defs/certificate_benchmark_case_category"
    },
    "handoff_file": { "type": "string", "minLength": 1 },
    "expect_cli_success": { "type": "boolean" },
    "expected_certificate_status": { "type": ["string", "null"] },
    "expected_failure_code": { "type": ["string", "null"] },
    "expect_counterexample": { "type": "boolean" },
    "expected_repair_hint": {
      "oneOf": [
        { "$ref": "common.defs.json#/$defs/expected_repair_hint_spec" },
        { "type": "null" }
      ]
    },
    "unsupported": { "type": "boolean" },
    "expect_formal_facts": { "type": "boolean" },
    "notes": { "type": ["string", "null"] }
  }
}
