# CertifyEdge — Bazel settings. Keep flags minimal and valid for the current build graph.

common --enable_bzlmod
common --lockfile_mode=off

build --incompatible_strict_action_env
build --show_timestamps
build --verbose_failures

build:linux --copt=-fPIC
build:macos --copt=-fPIC
build:windows --copt=/bigobj

# CI: reproducible, no machine-specific resource caps
build:ci --compilation_mode=fastbuild
build:ci --worker_sandboxing=false

test:ci --test_output=errors
test:ci --test_summary=detailed

# rules_rust crate_universe runs Cargo; inherit CARGO_HOME from the shell (see scripts/bazel-pcs-test.sh).
build:ci --action_env=CARGO_HOME
test:ci --action_env=CARGO_HOME
